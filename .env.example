# Mainnet RPC for fork tests in contracts/test/ExecutorFork.t.sol and for the
# bot's WebSocket scanner. Free public endpoints work for occasional runs;
# Alchemy / Infura are recommended for archival queries and rate limit headroom.
#
#   MAINNET_RPC_URL=https://eth.llamarpc.com
#   MAINNET_RPC_URL=https://ethereum-rpc.publicnode.com
#   MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/<your-key>
MAINNET_RPC_URL=

# WebSocket endpoint for live mempool ingestion. Required by `bun run scanner`.
# Most providers offer ws:// alongside their https:// — same key.
#
#   WS_URL=wss://eth-mainnet.g.alchemy.com/v2/<your-key>
WS_URL=

# Optional pin for ExecutorFork.t.sol — defaults to a known-good recent block.
# Override if the default block isn't archived by your RPC, or to replay a
# specific historical arb opportunity.
FORK_BLOCK=
